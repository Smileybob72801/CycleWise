<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base XML theme applied before Compose initialises.
      Transparent system bars let the Compose layer draw edge-to-edge.
    -->
    <style name="Theme.RhythmWise" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme (used only during cold start) -->
    <style name="Theme.RhythmWise.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#8B5E83</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.RhythmWise</item>
    </style>
</resources>
