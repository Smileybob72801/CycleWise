    <string name="hint_tracker_welcome_title">Your Cycle Calendar</string>
    <string name="hint_tracker_welcome_body">This calendar shows your periods, predicted phases, and logged data at a glance. We have seeded a few demo cycles so it is not empty.</string>
    <string name="hint_tracker_nav_title">Navigate Months</string>
    <string name="hint_tracker_nav_body">Use the arrows to move between months, or tap Today to jump back to the current month.</string>
    <string name="hint_tracker_phase_legend_title">Phase Legend</string>
    <string name="hint_tracker_phase_legend_body">These colors represent your cycle phases. You can customize them in Settings.</string>
    <string name="hint_tracker_long_press_title">Mark a Period Day</string>
    <string name="hint_tracker_long_press_body">Long-press any day to toggle it as a period day. The app merges adjacent days into one period automatically.</string>
    <string name="hint_tracker_drag_title">Select a Range</string>
    <string name="hint_tracker_drag_body">After long-pressing, drag across multiple days to mark or unmark an entire range at once.</string>
    <string name="hint_tracker_adjust_title">Adjust Period Edges</string>
    <string name="hint_tracker_adjust_body">Long-press the first or last day of a period and drag inward to shorten it, or outward to extend it.</string>
    <string name="hint_tracker_tap_day_title">View Day Details</string>
    <string name="hint_tracker_tap_day_body">Tap any day to see a summary of what you logged. From there you can open the full daily log to edit.</string>

