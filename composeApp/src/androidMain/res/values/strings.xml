    <string name="hint_daily_log_welcome_title">Welcome to Your Daily Log</string>
    <string name="hint_daily_log_welcome_body">This is where you record how you are feeling each day. We have seeded a few demo cycles so your calendar and insights are not empty. Let us walk you through the features.</string>
    <string name="hint_daily_log_mood_title">Track Your Mood</string>
    <string name="hint_daily_log_mood_body">Tap a star to rate how you are feeling today. Mood data feeds into your Insights over time.</string>
    <string name="hint_daily_log_energy_title">Log Your Energy</string>
    <string name="hint_daily_log_energy_body">Rate your energy level from 1 to 5. Patterns often correlate with your cycle phase.</string>
    <string name="hint_daily_log_water_title">Stay Hydrated</string>
    <string name="hint_daily_log_water_body">Tap the plus button to log each cup of water. You can also log water from the lock screen.</string>
    <string name="hint_daily_log_explore_tabs_title">Explore the Tabs</string>
    <string name="hint_daily_log_explore_tabs_body">Each tab focuses on a different part of your day. Swipe or tap a tab to switch between them.</string>
    <string name="hint_daily_log_period_tab_title">The Period Tab</string>
    <string name="hint_daily_log_period_tab_body">This is where you log period flow, color, and consistency. Tap this tab to continue.</string>
    <string name="hint_daily_log_period_toggle_title">Mark a Period Day</string>
    <string name="hint_daily_log_period_toggle_body">Toggle this on when your period starts. The app creates and tracks your cycles automatically.</string>
    <string name="hint_daily_log_symptoms_tab_title">The Symptoms Tab</string>
    <string name="hint_daily_log_symptoms_tab_body">Log any symptoms you experience. Over time, Insights will show which symptoms recur in each cycle phase.</string>
    <string name="hint_daily_log_medications_tab_title">The Medications Tab</string>
    <string name="hint_daily_log_medications_tab_body">Track which medications you take each day. Create your own entries to build a personal library.</string>
    <string name="hint_daily_log_notes_tab_title">Notes &amp; Tags</string>
    <string name="hint_daily_log_notes_tab_body">Add freeform notes or quick tags. This is your private journal — write anything you want to remember.</string>
    <string name="coach_mark_no_periods">I don\'t have periods</string>
    <string name="coach_mark_no_periods_toast">No problem — you can still track mood, energy, symptoms, and more.</string>

